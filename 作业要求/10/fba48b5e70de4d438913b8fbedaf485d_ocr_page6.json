=\"com.my.blog.dao.MenuMapper\">\n      <select id=\"getPerms\" resultType=\"java.lang.String\">\n            select\n                distinct sm.perms\n            from\n                sys_user_role sur\n                left join sys_role_menu srm on sur.role_id = srm.role_id\n                left join sys_menu sm on srm.menu_id = sm.id\n            where\n                sur.user_id = #{id} and\n                sm.menu_type in ('C', 'F') and\n                sm.status = 0 and\n                sm.del_flag = 0\n      </select>\n  </mapper>\n```","Level":0,"Polygon":{"LeftBottom":{"X":225,"Y":2069},"LeftTop":{"X":225,"Y":1238},"RightBottom":{"X":1355,"Y":2069},"RightTop":{"X":1355,"Y":1238}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":12,"Type":"paragraph","Text":"② 根据用户id查询角色信息 roleService.getRoleKey()","Level":0,"Polygon":{"LeftBottom":{"X":224,"Y":2231},"LeftTop":{"X":224,"Y":2178},"RightBottom":{"X":957,"Y":2231},"RightTop":{"X":957,"Y":2178}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":13,"Type":"paragraph","Text":"IRoleService","Level":0,"Polygon":{"LeftBottom":{"X":220,"Y":2294},"LeftTop":{"X":220,"Y":2254},"RightBottom":{"X":400,"Y":2294},"RightTop":{"X":400,"Y":2254}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""},{"Index":14,"Type":"code","Text":"List<String> getRoleKey(Long id);","Level":0,"Polygon":{"LeftBottom":{"X":249,"Y":2398},"LeftTop":{"X":249,"Y":2347},"RightBottom":{"X":784,"Y":2398},"RightTop":{"X":784,"Y":2347}},"InsetImageName":"","Elements":null,"ImagePath":"","group_id":-1,"group_type":""}]}